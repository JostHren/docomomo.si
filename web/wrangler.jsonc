{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "docomomo",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "docomomo.si",
      "custom_domain": true
    }
  ]
}
